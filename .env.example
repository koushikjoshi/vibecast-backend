# ─── Core ──────────────────────────────────────────────────────────────────────
ENV=development                    # development | production
PORT=8000
LOG_LEVEL=INFO
# Comma-separated origins allowed by CORS (your Vercel URL(s) + localhost)
CORS_ORIGINS=http://localhost:3000,https://vibecast.vercel.app
# Shared secret between frontend and backend for internal endpoints
INTERNAL_API_KEY=change-me-to-a-long-random-string
# Public base URL of the deployed backend (used in RSS links, share URLs)
PUBLIC_BACKEND_URL=https://api.vibecast.example.com
# Public base URL of the frontend (used in share links)
PUBLIC_FRONTEND_URL=https://vibecast.vercel.app

# ─── LLM providers ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Optional, used if we route some agents to Claude
ANTHROPIC_API_KEY=

# Default model per role (override if you want)
MODEL_EDITOR=gpt-4o-mini
MODEL_RESEARCHER=gpt-4o-mini
MODEL_BOOKER=gpt-4o-mini
MODEL_HOST=gpt-4o
MODEL_ENGINEER=gpt-4o-mini
MODEL_PUBLISHER=gpt-4o-mini

# ─── TTS / voices ──────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
# Fallback when ElevenLabs rate-limits
OPENAI_TTS_VOICE_FALLBACK=alloy

# ─── Data sources ──────────────────────────────────────────────────────────────
# HackerNews has no key. These are optional:
FIRECRAWL_API_KEY=                 # for URL scraping (optional, falls back to readability)
TAVILY_API_KEY=                    # for web search (optional)

# ─── Storage ───────────────────────────────────────────────────────────────────
# SQLite path (relative to app working dir)
DB_PATH=./data/vibecast.db
# Where MP3s and clips land locally before (optional) S3 upload
MEDIA_DIR=./public/media

# Optional object storage for audio files (S3-compatible)
S3_ENDPOINT_URL=
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# ─── Observability ─────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
COST_ALERT_USD=2.00

# ─── Sanity (optional, if you decide to use it for hosts/episodes metadata) ────
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2024-01-01
SANITY_READ_TOKEN=
SANITY_WRITE_TOKEN=
